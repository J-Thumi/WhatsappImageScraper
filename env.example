# ─────────────────────────────────────────────────────────────────────────────
# Kufai WhatsApp Menu Extractor — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# Phone number of the WhatsApp contact or group to scrape (digits only, no spaces or +)
TARGET_NUMBER=254712345678

# Display name of the contact or group (used as fallback if number lookup fails)
CONTACT_NAME=My WhatsApp Contact

# ── Optional — sensible defaults are used if not set ─────────────────────────

# Express server port
PORT=3000

# How many messages to fetch from the chat history
FETCH_TARGET=120

# Root folder where images and JSON output are saved
OUTPUT_DIR=kufai_output

# Currency prefix used in price strings
CURRENCY=Ksh

# Run Chrome in headless mode (no visible window). Set to true on servers / CI.
HEADLESS=false

# ── Timing / performance tuning ───────────────────────────────────────────────

# Maximum number of scroll attempts when loading older messages
MAX_SCROLL_ATTEMPTS=50

# Milliseconds to wait between each scroll step
SCROLL_PAUSE_MS=2000

# Milliseconds to wait for the chat/player to finish loading
PLAY_WAIT_MS=3000

# Download this many images before pausing (to avoid hammering the server)
BATCH_SIZE=10

# Milliseconds to sleep between batches
BATCH_SLEEP_MS=300

# How many times to call loadEarlierMessages() if fetchMessages returns too few results
LOAD_EARLIER_RETRIES=5

# Stop scrolling after this many consecutive scroll attempts with no new messages
NO_CHANGE_THRESHOLD=5
